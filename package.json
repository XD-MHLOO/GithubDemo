{
  "name": "ts-monorepo",
  "description": "Template for setting up a TypeScript monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "docs": "doctoc --title '**Table of content**' README.md",
    "clean": "pnpm run -r clean",
    "build": "pnpm run -r build",
    "test": "pnpm run -r test",
    "lint": "eslint .",
    "frontend": "pnpm --filter frontend dev",
    "backend": "pnpm --filter backend dev",
    "orchestrator": "pnpm --filter orchestrator dev",
    "dev": "mkdir -p ./nginx/conf.d && chmod 777 ./nginx/conf.d && pnpm run --filter ./apps/orchestrator --filter ./apps/backend --filter ./apps/frontend --parallel dev",
    "prisma-migrate": "cd packages/libraries && pnpm prisma migrate deploy",
    "pm2-start": "pm2-runtime start ecosystem.config.js",
    "pm2-run": "pm2 delete all || true && pnpm run prisma-migrate && pnpm run pm2-start"
  },
  "dependencies": {
    "@langchain/core": "^1.1.45",
    "@langchain/google-genai": "^2.1.28",
    "@langchain/langgraph": "^1.2.9",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.1",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/platform-express": "~11.1.0",
    "@phukon/duckduckgo-search": "^1.2.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@temporalio/activity": "^1.17.0",
    "@temporalio/client": "^1.16.1",
    "@temporalio/common": "^1.16.1",
    "@temporalio/worker": "^1.16.1",
    "@temporalio/workflow": "^1.16.1",
    "axios": "^1.15.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dayjs": "^1.11.20",
    "diff": "^9.0.0",
    "dockerode": "^5.0.0",
    "duckduckgo-search": "^1.0.7",
    "fast-xml-parser": "^5.7.1",
    "form-data": "^4.0.5",
    "ioredis": "^5.10.1",
    "isomorphic-git": "^1.37.6",
    "jose": "^4.15.9",
    "js-yaml": "^4.1.1",
    "micromatch": "^4.0.8",
    "multer": "^2.1.1",
    "nestjs-temporal-core": "^3.2.7",
    "normalize-url": "^9.0.0",
    "path": "^0.12.7",
    "prisma": "^7.8.0",
    "qs": "^6.15.1",
    "repomix": "^1.13.1",
    "rimraf": "~6.1.0",
    "tar": "^7.5.13",
    "tar-fs": "^3.1.2",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@eslint/js": "~9.39.0",
    "@nestjs/cli": "~11.0.0",
    "@nestjs/common": "~11.1.0",
    "@nestjs/core": "~11.1.0",
    "@types/express": "~5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "~24.12.0",
    "@types/qs": "^6.15.0",
    "@types/tar-fs": "^2.0.4",
    "doctoc": "~2.4.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "~9.39.0",
    "eslint-plugin-prettier": "~5.5.0",
    "eslint-plugin-react": "~7.37.4",
    "globals": "~17.4.0",
    "prettier": "~3.8.0",
    "reflect-metadata": "~0.2.2",
    "rimraf": "~6.1.0",
    "rxjs": "~7.8.0",
    "ts-node": "~10.9.0",
    "tsconfig-paths": "~4.2.0",
    "typescript": "~5.9.0",
    "typescript-eslint": "~8.58.0"
  },
  "packageManager": "pnpm@10.33.0"
}
